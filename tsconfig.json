{
    "compilerOptions": {
        "target": "ES2020",
        "types": ["node"],
        "moduleResolution": "node16",
        "module": "node16",
        "outDir": "./dist",
        "rootDir": "./server",
        "strict": false,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
    },
    "include": [
        "server/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}